rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Per-user weights — sync key acts as the secret
    match /users/{userId}/weights/{weightId} {
      allow read, write: if true;
    }
    // Per-user reminders and device tokens
    match /users/{userId}/reminders/{reminderId} {
      allow read, write: if true;
    }
    match /users/{userId}/devices/{deviceId} {
      allow read, write: if true;
    }
    // Collection-group reads — needed for backup and reminder sender
    match /{path=**}/weights/{weightId} {
      allow read: if true;
    }
  }
}
