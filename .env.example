# Firebase Configuration — copy this file to .env and fill in your values
# Firebase Console > Project Settings > General > Your apps > SDK setup and configuration
# Without this config the app works fully with localStorage (no setup required).

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
# Firebase Cloud Messaging > Web Push certificates > Generate key pair
VITE_FIREBASE_VAPID_KEY=your_vapid_key_here
